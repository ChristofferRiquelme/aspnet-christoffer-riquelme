@page
@model LoginModel

@{
    ViewData["Title"] = "Sign In";
    ViewData["HideFooter"] = true;
}

<section class="min-h-screen flex items-center justify-center bg-[#F3F3F3] px-4 py-20">
    <div class="w-full max-w-[920px] bg-white rounded-3xl px-10 md:px-20 py-12 md:py-16">

        <div class="mb-12">
            <h1 class="font-poppins text-[56px] font-medium text-black mb-4">
                Welcome Back!
            </h1>

            <p class="font-dm text-gray-500 max-w-[760px] leading-relaxed">
                Log in to continue your fitness journey with full access to your customized program,
                training history, and progress tracking. Stay consistent, monitor your development,
                and keep moving forward with the structure and support built into your account.
            </p>
        </div>

        <div class="border-t mb-16"></div>

        <div class="flex justify-center gap-4 mb-16">
            <button type="button" class="w-16 h-16 flex items-center justify-center">
                <img src="/images/icons/google.svg" class="w-16 h-16" />
            </button>

            <button type="button" class="w-16 h-16 flex items-center justify-center">
                <img src="/images/icons/facebook.svg" class="w-16 h-16" />
            </button>

            <button type="button" class="w-16 h-16 flex items-center justify-center">
                <img src="/images/icons/github.svg" class="w-16 h-16" />
            </button>
        </div>

        <div class="flex items-center gap-6 mb-14">
            <div class="h-px bg-gray-200 flex-1"></div>
            <span class="font-dm text-gray-500 uppercase">Or continue with</span>
            <div class="h-px bg-gray-200 flex-1"></div>
        </div>

        <form method="post">
            <div asp-validation-summary="ModelOnly" class="text-red-500 font-dm text-sm mb-4"></div>

            <div class="mb-7">
                <label asp-for="Input.Email" class="block font-dm font-semibold text-[#2A2934] mb-3">
                    Email Address *
                </label>

                <input asp-for="Input.Email"
                       placeholder="Enter Email Address"
                       class="w-full bg-[#F5F5F5] rounded-xl px-7 py-5 font-dm outline-none" />

                <span asp-validation-for="Input.Email" class="text-red-500 text-sm font-dm"></span>
            </div>

            <div class="mb-12">
                <div class="flex justify-between items-center mb-3">
                    <label asp-for="Input.Password" class="block font-dm font-semibold text-[#2A2934]">
                        Password
                    </label>

                    <a asp-page="./ForgotPassword" class="font-dm text-sm font-semibold text-[#D6EB31]">
                        Forgot your password?
                    </a>
                </div>

                <input asp-for="Input.Password"
                       placeholder="Enter Password"
                       class="w-full bg-[#F5F5F5] rounded-xl px-7 py-5 font-dm outline-none" />

                <span asp-validation-for="Input.Password" class="text-red-500 text-sm font-dm"></span>
            </div>

            <button type="submit"
                    class="mx-auto mb-10 flex w-[70%] items-center justify-center gap-6 bg-[#D6EB31] text-black px-7 py-5 rounded-full font-dm font-semibold text-lg hover:bg-lime-300 transition">
                Continue
                <img src="/images/icons/arrow-right.svg" class="w-[10px] h-4" />
            </button>

            <label class="flex items-center justify-center gap-5 font-dm text-[#2A2934]">
                <input asp-for="Input.RememberMe"
                       class="w-8 h-8 rounded-lg accent-[#D6EB31]" />
                Accept user terms and conditions
            </label>
        </form>

    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}