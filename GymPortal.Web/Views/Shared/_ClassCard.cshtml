@using GymPortal.Domain
@model GymClass

@{
    var isBooked = ViewData["IsBooked"] as bool? ?? false;
}

<div class="p-5 bg-white shadow-md rounded-2xl hover:shadow-lg transition">
    <h2 class="text-xl font-bold">@Model.Name</h2>

    <div class="text-sm text-gray-500 mt-2">
        <p>@Model.Date.ToString("dddd HH:mm")</p>
        <p>👤 @Model.Instructor</p>
        <p>🏷️ @Model.Category</p>
    </div>
</div>

@if (User.Identity!.IsAuthenticated)
{
    if (isBooked)
    {
        <form asp-controller="Booking" asp-action="Cancel" method="post" class="mt-4">
            <input type="hidden" name="classId" value="@Model.Id" />

            <button class="bg-red-500 text-white px-4 py-2 rounded hover:bg-red-600">
                Cancel
            </button>
        </form>
    }
    else
    {
        <form asp-controller="Booking" asp-action="Book" method="post" class="mt-4">
            <input type="hidden" name="classId" value="@Model.Id" />

            <button class="bg-blue-500 text-white px-4 py-2 rounded hover:bg-blue-600">
                Book
            </button>
        </form>
    }
}