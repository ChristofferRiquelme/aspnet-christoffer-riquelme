@using GymPortal.Domain
@model List<GymClass>

<div class="max-w-4xl mx-auto p-6">
    <h1 class="text-3xl font-bold mb-6">Mina bokningar</h1>

    @if (!Model.Any())
    {
        <p class="text-gray-500">Du har inga bokningar än.</p>
    }
    else
    {
        <div class="grid gap-4">
            @foreach (var item in Model)
            {
                <partial name="_ClassCard" model="item" />
            }
        </div>
    }
</div>