@{
    ViewData["Title"] = "Home Page";
    ViewData["HideNavbar"] = true;
    ViewData["IsHomeHero"] = true;
}

<section class="m-4 rounded-2xl overflow-hidden bg-[#131020] relative">

    <div class="absolute inset-0 bg-[url('/images/backgrounds/dark-section-img.svg')] bg-repeat opacity-60 pointer-events-none"></div>

    <div class="relative z-10">
        <partial name="_Navbar" />

        <div class="grid grid-cols-2 items-end max-w-[1320px] mx-auto px-16 pt-20 min-h-[620px]">

            <div class="text-white pb-32">
                <div class="inline-flex items-center gap-2 bg-white/10 px-4 py-2 rounded-full text-xs mb-6 text-white font-dm text-[14px]">
                    <img src="/images/icons/dot.svg" class="w-2 h-2" />
                    <span>Strong Body. Strong Mind.</span>
                </div>

                <h1 class="font-poppins text-[54px] font-bold leading-tight mb-6">
                    Build Strength Boost<br />
                    Confidence Today!
                </h1>

                <p class="font-dm max-w-[520px] mb-8">
                    Begin your fitness journey with expert trainers, modern equipment, and a supportive environment designed to help you build strength and confidence.
                </p>

                <div class="grid grid-cols-2 gap-y-3 gap-x-6 text-sm font-dm font-semibold text-white mb-10">
                    <div class="flex items-center gap-2">
                        <img src="/images/icons/check.svg" class="w-4 h-4" />
                        <span>Transform your body with training</span>
                    </div>

                    <div class="flex items-center gap-2">
                        <img src="/images/icons/check.svg" class="w-4 h-4" />
                        <span>Personal training for real results</span>
                    </div>

                    <div class="flex items-center gap-2">
                        <img src="/images/icons/check.svg" class="w-4 h-4" />
                        <span>Build confidence through fitness</span>
                    </div>

                    <div class="flex items-center gap-2">
                        <img src="/images/icons/check.svg" class="w-4 h-4" />
                        <span>Fitness tailored to your goals</span>
                    </div>
                </div>

                <div class="my-10 h-px w-[580px] bg-[#D6EB31]/20"></div>

                <a href="#" class="inline-flex items-center gap-3 bg-[#D6EB31] text-black px-6 py-[15px] rounded-full font-semibold text-sm">
                    Get Started
                    <img src="/images/icons/arrow-right.svg" class="w-[10px] h-4" />
                </a>
            </div>

            <div class="relative h-full min-h-[620px]">
                <img src="/images/backgrounds/members.svg"
                    class="absolute right-0 bottom-0 h-[650px] max-w-none" />
            </div>
        </div>
    </div>
</section>

<section class="mx-4 mt-4 rounded-2xl overflow-hidden bg-[#D6EB31] h-[84px]">
    <img src="/images/backgrounds/banner.svg"
         alt="Modern Equipment banner"
         class="block w-full h-full object-cover" />
</section>

<section class="w-full bg-gradient-to-b from-[#F3F3F3] via-[#F8F8F8] to-white py-24">

    <div class="mx-auto max-w-[1320px] px-4">

        <div class="grid grid-cols-2 items-center gap-10">

            <div>
                <img src="/images/backgrounds/left-column.svg"
                     alt="Gym training"
                     class="w-full" />
            </div>

            <div>
                <div class="inline-flex items-center gap-2 bg-[#2A2934] text-white px-4 py-2 rounded-full font-dm text-sm font-semibold mb-6">
                    <span class="w-2 h-2 bg-[#D6EB31] rounded-full"></span>
                    About Us
                </div>

                <h2 class="font-poppins text-[48px] font-medium text-[#2A2934] leading-tight mb-6">
                    Elevating Fitness Journey
                    with Expert Guidance
                </h2>

                <p class="text-gray-500 font-dm mb-10 max-w-[520px]">
                    We support every stage of your fitness journey with certified trainers,
                    personalized programs proven methods designed to help you train safely,
                    build strength.
                </p>

                <div class="relative bg-white rounded-2xl p-8 max-w-[520px] shadow-sm">

                    <img src="/images/backgrounds/quote.svg"
                         class="absolute right-6 top-6 w-12 opacity-30 pointer-events-none" />

                    <p class="font-dm font-semibold text-[#2A2934] text-sm leading-relaxed">
                        Our mission is to transform lives by combining expert guidance,
                        powerful training programs, and a motivating community that helps
                        you grow stronger every day.
                    </p>
                </div>
            </div>

        </div>

    </div>

</section>

<section class="w-full bg-white py-24">
    <div class="mx-auto max-w-[1320px] px-4 text-center">
        <div class="inline-flex items-center gap-2 bg-[#2A2934] text-white px-4 py-2 rounded-full font-dm text-sm font-semibold mb-10">
            <span class="w-2 h-2 bg-[#D6EB31] rounded-full"></span>
            Our Programs
        </div>

        <h2 class="font-poppins text-[48px] font-medium text-[#2A2934] leading-tight mb-12">
            Professional training program<br />
            for stronger health
        </h2>

        <div class="grid grid-cols-3 gap-8 mb-10">
            <img src="/images/backgrounds/program-left.svg"
                 class="w-full rounded-2xl object-cover transition duration-300 hover:scale-105" />

            <img src="/images/backgrounds/program-middle.svg"
                 class="w-full rounded-2xl object-cover transition duration-300 hover:scale-105" />

            <img src="/images/backgrounds/program-right.svg"
                 class="w-full rounded-2xl object-cover transition duration-300 hover:scale-105" />
        </div>

        <p class="font-dm text-sm font-semibold">
            Let’s make something great work together.
            <a href="#" class="underline font-semibold">
                Get Free Quote
            </a>
        </p>
    </div>
</section>

<section class="w-full bg-[#F3F3F3] py-24">

    <div class="mx-auto max-w-[1320px] px-4 text-center">

        <!-- Label -->
        <div class="inline-flex items-center gap-2 bg-[#2A2934] text-white px-4 py-2 rounded-full font-dm text-sm font-semibold mb-8">
            <span class="w-2 h-2 bg-[#D6EB31] rounded-full"></span>
            Our Store
        </div>

        <!-- Title -->
        <h2 class="font-poppins text-[48px] font-medium text-[#2A2934] leading-tight mb-20">
            High quality fitness products<br />
            built for results
        </h2>

        <!-- Products -->
        <div class="grid grid-cols-4 gap-8 mb-14">

            <div class="bg-white rounded-2xl h-[280px] flex items-center justify-center">
                <img src="/images/backgrounds/weight.svg"
                     alt="Weight"
                     class="max-h-[170px] max-w-[220px]" />
            </div>

            <div class="bg-white rounded-2xl h-[280px] flex items-center justify-center">
                <img src="/images/backgrounds/bag.svg"
                     alt="Gym bag"
                     class="max-h-[170px] max-w-[220px]" />
            </div>

            <div class="bg-white rounded-2xl h-[280px] flex items-center justify-center">
                <img src="/images/backgrounds/watch.svg"
                     alt="Fitness watch"
                     class="max-h-[170px] max-w-[220px]" />
            </div>

            <div class="bg-white rounded-2xl h-[280px] flex items-center justify-center">
                <img src="/images/backgrounds/treadmill.svg"
                     alt="Treadmill"
                     class="max-h-[170px] max-w-[220px]" />
            </div>

        </div>

        <p class="font-dm text-sm text-black font-semibold">
            Let’s make something great work together.
            <a href="#" class="underline">
                Get Free Quote
            </a>
        </p>

    </div>

</section>