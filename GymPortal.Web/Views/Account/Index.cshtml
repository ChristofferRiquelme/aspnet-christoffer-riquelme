@using GymPortal.Web.Models
@model AccountPageViewModel

<div class="mx-auto max-w-[1320px] mb-20">

    <h1 class="font-poppins text-4xl text-center my-10">
        My Account
    </h1>

    <div class="flex justify-center gap-8">

        <div class="w-1/3 space-y-12">

            <div class="bg-white rounded-xl shadow">
                <img src="@(string.IsNullOrEmpty(Model.User.ProfileImagePath) ? "/images/account/user.avif" : Model.User.ProfileImagePath)"
                    class="rounded-xl w-full object-cover">
            </div>

            <div class="bg-white rounded-xl shadow overflow-hidden">
                <div class="bg-[#D6EB31] px-7 py-4 font-poppins text-xs font-semibold">
                    Menu Options
                </div>

                <div class="px-7 py-4">
                <a asp-action="Index" class="group flex justify-between font-poppins text-xs font-semibold @(Model.ActiveSection == "About" ? "text-[#D6EB31]" : "text-black hover:text-[#D6EB31]")">
                    About Me 
                    <span class="relative w-3 h-4">
                        <img src="/images/icons/arrow-right.svg" alt="Arrow" class="absolute inset-0 @(Model.ActiveSection == "About" ? "hidden" : "group-hover:hidden")">
                        <img src="/images/icons/arrow-right-hover.svg" alt="Arrow" class="absolute inset-0 @(Model.ActiveSection == "About" ? "block" : "hidden group-hover:block")">
                    </span>
                </a>
                <div class="border-t my-4"></div>

                <a asp-controller="Account" asp-action="Membership" class="group flex justify-between font-poppins text-xs font-semibold @(Model.ActiveSection == "Membership" ? "text-[#D6EB31]" : "text-black hover:text-[#D6EB31]")">
                    My Membership
                    <span class="relative w-3 h-4">
                        <img src="/images/icons/arrow-right.svg" alt="Arrow" class="absolute inset-0 @(Model.ActiveSection == "Membership" ? "hidden" : "group-hover:hidden")">
                        <img src="/images/icons/arrow-right-hover.svg" alt="Arrow" class="absolute inset-0 @(Model.ActiveSection == "Membership" ? "block" : "hidden group-hover:block")">
                    </span>
                </a>
                <div class="border-t my-4"></div>

                <a asp-controller="Account" asp-action="Bookings" class="group flex justify-between font-poppins text-xs font-semibold @(Model.ActiveSection == "Bookings" ? "text-[#D6EB31]" : "text-black hover:text-[#D6EB31]")">
                    My Bookings
                    <span class="relative w-3 h-4">
                        <img src="/images/icons/arrow-right.svg" alt="Arrow" class="absolute inset-0 @(Model.ActiveSection == "Bookings" ? "hidden" : "group-hover:hidden")">
                        <img src="/images/icons/arrow-right-hover.svg" alt="Arrow" class="absolute inset-0 @(Model.ActiveSection == "Bookings" ? "block" : "hidden group-hover:block")">
                    </span>
                </a>
                <div class="border-t my-4"></div>

                <form asp-area="Identity" asp-page="/Account/Logout" method="post">
                    <button class="group w-full text-left flex justify-between hover:text-[#D6EB31] transition font-poppins text-xs font-semibold">
                        Sign Out
                        <span class="relative w-3 h-4">
                            <img src="/images/icons/arrow-right.svg" alt="Arrow" class="absolute inset-0 group-hover:hidden">
                            <img src="/images/icons/arrow-right-hover.svg" alt="Arrow" class="absolute inset-0 hidden group-hover:block">
                        </span>
                    </button>
                </form>
                </div>
            </div>

            <div class="text-center font-poppins">
                <p class="text-[10px] text-[#2A2934] mb-2">
                    If you like to cancel your account click below
                </p>

                <button type="button"
                        onclick="openDeleteModal()"
                        class="text-red-600 text-xs font-semibold hover:underline">
                    Remove Account
                </button>
            </div>

        </div>

        <div class="w-2/3 max-w-2x1">
        @if (Model.ActiveSection == "About")
        {
            <div class="bg-white p-6 rounded-xl shadow">
                <h2 class="font-poppins text-2xl">About Me</h2>
                <div class="border-t my-4"></div>

                <form asp-action="Edit" method="post" enctype="multipart/form-data">
                    <p class="font-poppins text-sm font-semibold mb-2">First Name</p>
                    <input asp-for="User.FirstName" placeholder="Enter First Name" class="w-full mb-3 p-3 bg-gray-100 rounded-lg font-dm text-xs">

                    <p class="font-poppins text-sm font-semibold mb-2">Last Name</p>
                    <input asp-for="User.LastName" placeholder="Enter Last Name" class="w-full mb-3 p-3 bg-gray-100 rounded-lg font-dm text-xs">

                    <p class="font-poppins text-sm font-semibold mb-2">Email Address *</p>
                    <input asp-for="User.Email" placeholder="username@domain.com" class="w-full mb-3 p-3 bg-gray-100 rounded-lg font-dm text-xs">

                    <p class="font-poppins text-sm font-semibold mb-2">Phone Number</p>
                    <input asp-for="User.PhoneNumberCustom" placeholder="Enter Phone Number" class="w-full mb-3 p-3 bg-gray-100 rounded-lg font-dm text-xs">

                    <div class="border-t mt-10 mb-5"></div>

                    <p class="font-poppins text-sm font-semibold mb-2">Profile Image</p>
                    <label class="flex items-center justify-between bg-[#F3F3F3] rounded-lg px-5 py-2 cursor-pointer shadow-sm">
                        <span id="fileName" class="text-gray-400 text-sm">
                            Upload Profile Image
                        </span>
                        <span class="bg-[#D9D9D9] px-5 py-2 rounded-xl text-sm font-semibold text-black">
                            Browse
                        </span>
                        <input type="file" name="profileImage" class="hidden" onchange="updateFileName(this)" />
                    </label>

                    <div class="mt-6 flex justify-end">
                        <button class="flex justify-evenly bg-[#D6EB31] py-4 w-24 rounded-full font-dm text-xs font-semibold">
                            Save<img src="/images/icons/arrow-right.svg" alt="Arrow" class=""/>
                        </button>
                    </div>
                </form>
            </div>
        }

        else if (Model.ActiveSection == "Bookings")
        {
            <div class="bg-white p-6 rounded-xl shadow">
                <h2 class="font-poppins text-2xl">Bookings</h2>
                <div class="border-t my-4"></div>

                @if (!Model.Bookings.Any())
                {
                    <p class="font-dm text-sm text-gray-500">
                        You have no bookings yet.
                    </p>
                }
                else
                {
                    <div class="space-y-4">
                        @foreach (var booking in Model.Bookings)
                        {
                            <div class="bg-gray-100 rounded-xl p-4">
                                <h3 class="font-poppins font-semibold">
                                    @booking.GymClass.Name
                                </h3>

                                <p class="font-dm text-xs text-gray-600">
                                    @booking.GymClass.Date.ToString("dddd dd MMMM HH:mm")
                                </p>

                                <p class="font-dm text-xs text-gray-600">
                                    Instructor: @booking.GymClass.Instructor
                                </p>

                                <p class="font-dm text-xs text-gray-600">
                                    Category: @booking.GymClass.Category
                                </p>

                                <form asp-controller="Booking" asp-action="Cancel" method="post" class="mt-3">
                                    <input type="hidden" name="classId" value="@booking.GymClassId" />

                                    <button class="bg-red-600 text-white px-4 py-2 rounded-full text-xs font-semibold">
                                        Cancel booking
                                    </button>
                                </form>
                            </div>
                        }
                    </div>
                }
            </div>
        }

        else if (Model.ActiveSection == "Membership")
        {
            <div class="bg-white p-6 rounded-xl shadow">
                <h2 class="font-poppins text-2xl">My Membership</h2>
                <div class="border-t my-4"></div>

                @if (Model.Membership == null || Model.Membership.EndDate < DateTime.Now)
                {
                    <p class="font-dm text-sm text-gray-500 mb-4">
                        You do not have an active membership.
                    </p>

                    <a asp-controller="Membership" asp-action="Index"
                    class="bg-[#D6EB31] px-4 py-2 rounded-full text-xs font-semibold">
                        Get Membership
                    </a>
                }
                else
                {
                    <div class="space-y-2 font-dm text-sm">
                        <p><strong>Status:</strong> Active</p>
                        <p><strong>Start:</strong> @Model.Membership.StartDate.ToShortDateString()</p>
                        <p><strong>End:</strong> @Model.Membership.EndDate.ToShortDateString()</p>
                    </div>
                }
            </div>
        }


            <h2 class="font-poppins text-2xl mt-14 mb-5">My Statistics</h2>
            <div class="bg-white p-6 rounded-xl shadow">

                <div class="space-y-4">

                    <div>
                        <div class="flex justify-between font-poppins text-sm">
                            <span>Check-In (last 30 days)</span>
                            <span>25</span>
                        </div>

                        <div class="h-2 bg-gray-200 rounded-full mt-1">
                            <div class="h-2 bg-[#D6EB31] rounded-full w-[95%]"></div>
                        </div>
                    </div>

                    <div>
                        <div class="flex justify-between font-poppins text-sm">
                            <span>Weight Goal</span>
                            <span>50%</span>
                        </div>

                        <div class="h-2 bg-gray-200 rounded-full mt-1">
                            <div class="h-2 bg-[#D6EB31] rounded-full w-[50%]"></div>
                        </div>
                    </div>

                    <div>
                        <div class="flex justify-between font-poppins text-sm">
                            <span>Current BMI</span>
                            <span>27</span>
                        </div>

                        <div class="h-2 bg-gray-200 rounded-full mt-1">
                            <div class="h-2 bg-[#D6EB31] rounded-full w-[65%]"></div>
                        </div>
                    </div>

                </div>
            </div>

        </div>

    </div>

</div>

<div id="deleteModal"
     class="fixed inset-0 bg-black/50 hidden items-center justify-center z-50">

    <div class="bg-white rounded-2xl shadow-xl p-8 max-w-sm w-full text-center">
        <h2 class="font-poppins text-2xl font-semibold mb-3">
            Remove account?
        </h2>

        <p class="font-dm text-sm text-gray-600 mb-6">
            Are you sure you want to remove your account? This action cannot be undone.
        </p>

        <div class="flex gap-4 justify-center">
            <button type="button"
                    onclick="closeDeleteModal()"
                    class="px-5 py-3 rounded-full bg-gray-200 font-dm text-sm font-semibold">
                Cancel
            </button>

            <form asp-controller="Account" asp-action="Delete" method="post">
                <button type="submit"
                        class="px-5 py-3 rounded-full bg-red-600 text-white font-dm text-sm font-semibold">
                    Remove
                </button>
            </form>
        </div>
    </div>
</div>



<script>
    function updateFileName(input) {
        const fileName = input.files[0]?.name || "Upload Profile Image";
        document.getElementById("fileName").textContent = fileName;
    }

        function openDeleteModal() {
        const modal = document.getElementById("deleteModal");
        modal.classList.remove("hidden");
        modal.classList.add("flex");
    }

    function closeDeleteModal() {
        const modal = document.getElementById("deleteModal");
        modal.classList.add("hidden");
        modal.classList.remove("flex");
    }
</script>
