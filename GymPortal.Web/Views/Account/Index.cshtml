@using GymPortal.Infrastructure
@model ApplicationUser

<div class="w-full max-w-full">

    <h1 class="font-poppins text-4xl text-center my-10">
        My Account
    </h1>

    <div class="max-w-4xl mx-auto flex justify-center gap-8">

        <div class="w-1/3 space-y-12">

            <div class="bg-white rounded-xl shadow">
                <img src="/images/account/img_0085.JPG"
                    class="rounded-xl w-full object-cover">
            </div>

            <div class="bg-white rounded-xl shadow overflow-hidden">
                <div class="bg-[#D6EB31] px-4 py-3 font-poppins text-xs font-semibold">
                    Menu Options
                </div>

                <a asp-action="Index" class="flex justify-between px-4 py-3 hover:text-[#D6EB31] font-poppins text-xs font-semibold">
                    About Me <span>›</span>
                </a>

                <a asp-controller="Membership" asp-action="Index" class="flex justify-between px-4 py-3 hover:text-[#D6EB31] font-poppins text-xs font-semibold">
                    My Membership <span>›</span>
                </a>

                <a asp-controller="Booking" asp-action="MyBookings" class="flex justify-between px-4 py-3 hover:text-[#D6EB31] font-poppins text-xs font-semibold">
                    My Bookings <span>›</span>
                </a>

                <form asp-area="Identity" asp-page="/Account/Logout" method="post">
                    <button class="w-full text-left flex justify-between px-4 py-3 hover:text-[#D6EB31] font-poppins text-xs font-semibold">
                        Sign Out <span>›</span>
                    </button>
                </form>
            </div>

        </div>

        <div class="w-2/3 space-y-6 max-w-2x1">

            <div class="bg-white p-6 rounded-xl shadow">
                <h2 class="font-poppins text-2xl">About Me</h2>
                <div class="border-t my-4"></div>

                <form asp-action="Edit">
                    <p class="font-poppins text-sm font-semibold mb-2">First Name</p>
                    <input type="text" placeholder="Enter First Name" class="w-full mb-3 p-3 bg-gray-100 rounded-lg font-dm text-xs">

                    <p class="font-poppins text-sm font-semibold mb-2">Last Name</p>
                    <input type="text" placeholder="Enter Last Name" class="w-full mb-3 p-3 bg-gray-100 rounded-lg font-dm text-xs">

                    <p class="font-poppins text-sm font-semibold mb-2">Email Address *</p>
                    <input type="email" placeholder="username@domain.com" class="w-full mb-3 p-3 bg-gray-100 rounded-lg font-dm text-xs">

                    <p class="font-poppins text-sm font-semibold mb-2">Phone Number</p>
                    <input type="text" placeholder="Enter Phone Number" class="w-full mb-3 p-3 bg-gray-100 rounded-lg font-dm text-xs">

                    <div class="border-t mt-10 mb-5"></div>

                    <p class="font-poppins text-sm font-semibold mb-2">Profile Image</p>
                    <input type="text" placeholder="Upload Profile Image" class="w-full p-3 bg-gray-100 rounded-lg font-dm text-xs">

                    <div class="mt-6 flex justify-end">
                        <button class="bg-[#D6EB31] px-6 py-2 rounded-full font-semibold">
                            Save >
                        </button>
                    </div>
                </form>
            </div>

            <h2 class="font-poppins text-2xl">My Statistics</h2>
            <div class="bg-white p-6 rounded-xl shadow">

                <div class="space-y-4">

                    <div>
                        <div class="flex justify-between font-poppins text-sm">
                            <span>Check-In (last 30 days)</span>
                            <span>25</span>
                        </div>

                        <div class="h-2 bg-gray-200 rounded-full mt-1">
                            <div class="h-2 bg-lime-400 rounded-full w-[95%]"></div>
                        </div>
                    </div>

                    <div>
                        <div class="flex justify-between font-poppins text-sm">
                            <span>Weight Goal</span>
                            <span>50%</span>
                        </div>

                        <div class="h-2 bg-gray-200 rounded-full mt-1">
                            <div class="h-2 bg-lime-400 rounded-full w-[50%]"></div>
                        </div>
                    </div>

                    <div>
                        <div class="flex justify-between font-poppins text-sm">
                            <span>Current BMI</span>
                            <span>27</span>
                        </div>

                        <div class="h-2 bg-gray-200 rounded-full mt-1">
                            <div class="h-2 bg-lime-400 rounded-full w-[65%]"></div>
                        </div>
                    </div>

                </div>
            </div>

        </div>

    </div>

</div>
